{
  "name": "backend-stock",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "npm run prisma:generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate --config src/prisma/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config src/prisma/prisma.config.ts",
    "prisma:studio": "prisma studio --config src/prisma/prisma.config.ts",
    "prisma:push": "prisma db push --config src/prisma/prisma.config.ts",
    "stock:sync:id": "nest start --entryFile jobs/stock-sync/entrypoints/stock-sync-id",
    "stock:sync:price:id": "ts-node src/jobs/stock-sync/entrypoints/stock-sync-price-id.ts",
    "stock:sync:corporate-action:id": "ts-node src/jobs/stock-sync/entrypoints/stock-sync-corporate-action-id.ts",
    "stock:sync:shares:id": "nest start --entryFile jobs/stock-sync/entrypoints/stock-sync-shares-id",
    "stock:sync:financial-statement:id": "ts-node src/jobs/stock-sync/entrypoints/stock-sync-financial-statement-id.ts",
    "stock:sync:ajaib-stock-market": "ts-node src/jobs/stock-sync/entrypoints/stock-sync-ajaib-stock-market-id.ts",
    "stock:test:ajaib": "ts-node test-ajaib-scrape.ts",
    "stock:sync:us": "nest start --entryFile stock-sync-us",
    "stock:sync:global": "nest start --entryFile stock-sync-global"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/websockets": "^11.1.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "bullmq": "^5.58.5",
    "ms": "^2.1.3",
    "nest-commander": "^3.20.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
